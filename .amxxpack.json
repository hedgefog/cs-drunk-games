{
  "compiler": {
    "version": "1.9",
    "addons": ["cstrike"]
  },
  "include": [
    "./.compiler/include",
    "./.thirdparty/reapi/addons/amxmodx/scripting/include"
  ],
  "thirdparty": {
    "dependencies": [
      {
        "name": "reapi",
        "url": "https://github.com/s1lentq/reapi/releases/download/5.21.0.252/reapi-bin-5.21.0.252.zip"
      },
      {
        "name": "cs-modding-kit",
        "url": "https://github.com/Hedgefog/cs-modding-kit/archive/refs/tags/1.2.0.tar.gz",
        "strip": 1,
        "filter": [
          "api_custom_entities.@(sma|inc)",
          "api_custom_weapons.@(sma|inc)",
          "api_rounds.@(sma|inc)"
        ]
      }
    ]
  },
  "input": {
    "scripts": ["./.thirdparty/cs-modding-kit", "./src/scripts"],
    "include": ["./.thirdparty/cs-modding-kit/include", "./src/include"],
    "assets": "./assets"
  },
  "output": {
    "base": "./dist",
    "plugins": "./addons/amxmodx/plugins",
    "scripts": "./addons/amxmodx/scripting",
    "include": "./addons/amxmodx/scripting/include",
    "assets": "./"
  },
  "rules": {
    "flatCompilation": true
  },
  "cli": {
    "templates": {
      "context": {
        "PLUGIN_VERSION": "1.0.0",
        "PLUGIN_AUTHOR": "Hedgehog Fog"
      }
    }
  }
}